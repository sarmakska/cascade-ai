# ============================================================================
# SarmaLink-AI — Environment Variables
# Copy this file to .env.local and fill in your own keys.
# Every provider below offers a free tier — no credit card needed.
# ============================================================================

# ── Your App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SarmaLink-AI"
NEXT_PUBLIC_COMPANY_NAME="Your Company"
# Where the root URL (/) redirects to. Default: SarmaLink-AI product page.
# Self-hosters: change to "/login" or your own landing page
# NEXT_PUBLIC_HOME_REDIRECT="/login"

# ── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated Supabase user IDs or emails that can access /api/admin/health
# If both are empty, ALL authenticated users can access the health endpoint
# ADMIN_USER_IDS="uuid-1,uuid-2"
# ADMIN_EMAILS="admin@yourcompany.com"

# ── Supabase (database + auth) ───────────────────────────────────────────────
# Sign up: https://supabase.com (free tier: 1GB database)
# Create a project, then find these in Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Groq (primary chat — fastest inference) ──────────────────────────────────
# Sign up: https://console.groq.com (free, Google sign-in)
# You can create multiple accounts for more capacity
GROQ_API_KEY="gsk_your_key_here"
# Optional: add more keys for higher throughput
# GROQ_API_KEY_2="gsk_..."
# GROQ_API_KEY_3="gsk_..."

# ── SambaNova (DeepSeek V3.2 — frontier reasoning) ──────────────────────────
# Sign up: https://cloud.sambanova.ai (free, Google sign-in)
SAMBANOVA_API_KEY="your-sambanova-key"
# SAMBANOVA_API_KEY_2="..."

# ── Cerebras (ultra-fast inference — 2000 tok/sec) ───────────────────────────
# Sign up: https://cloud.cerebras.ai (free, Google sign-in)
CEREBRAS_API_KEY="csk-your-key"
# CEREBRAS_API_KEY_2="csk-..."

# ── Google Gemini (live web search + PDF reading) ────────────────────────────
# Sign up: https://aistudio.google.com/app/apikey (free, Google account)
# Or via Cloud Console: https://console.cloud.google.com
GOOGLE_GEMINI_API_KEY="AIzaSy..."
# GOOGLE_GEMINI_API_KEY_2="AIzaSy..."

# ── OpenRouter (free model fallback pool) ────────────────────────────────────
# Sign up: https://openrouter.ai (free, Google sign-in)
# Use models ending in :free for zero cost
OPENROUTER_API_KEY="sk-or-v1-..."

# ── Tavily (web search) ─────────────────────────────────────────────────────
# Sign up: https://app.tavily.com (free, 1000 searches/month)
TAVILY_API_KEY="tvly-..."
# TAVILY_API_KEY_2="tvly-..."

# ── Cloudflare Workers AI (image generation + editing) ───────────────────────
# Sign up: https://dash.cloudflare.com (free, 10K neurons/day)
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_TOKEN="your-token"
# Optional: more accounts for more image capacity
# CLOUDFLARE_ACCOUNT_ID_2="..."
# CLOUDFLARE_API_TOKEN_2="..."

# ── Cloudflare R2 (file storage — 10GB free) ─────────────────────────────────
# Create an R2 bucket in your Cloudflare dashboard
# Then create an API token with R2 read/write permissions
R2_ACCOUNT_ID="your-r2-account-id"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_BUCKET_NAME="sarmalink-ai-attachments"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
